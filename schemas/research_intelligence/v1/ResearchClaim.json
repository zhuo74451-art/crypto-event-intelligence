{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/ResearchClaim.json",
  "title": "ResearchClaim",
  "description": "A claim derived from one or more research sources.",
  "type": "object",
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "claim_type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "priority": {
      "type": "string"
    },
    "quality": {
      "type": "string"
    },
    "statement": {
      "type": "string"
    },
    "methodology": {
      "type": "string"
    },
    "observation_period": {
      "type": "string"
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counter_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}