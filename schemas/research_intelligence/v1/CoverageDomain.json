{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/CoverageDomain.json",
  "title": "CoverageDomain",
  "description": "Describes how well a particular topic / domain is covered by research.",
  "type": "object",
  "properties": {
    "domain_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "level": {
      "type": "string"
    },
    "parent_domain_id": {
      "type": "string"
    },
    "subdomain_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assessed_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}