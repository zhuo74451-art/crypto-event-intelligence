{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/Specification.json",
  "title": "Specification",
  "description": "Full specification for a strategy candidate.",
  "type": "object",
  "properties": {
    "datasets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "splits": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_type": {
      "type": "string"
    },
    "hyperparameters": {
      "type": "object",
      "additionalProperties": true
    },
    "abstention_logic": {
      "type": "string"
    },
    "invalidation_criteria": {
      "type": "string"
    }
  }
}