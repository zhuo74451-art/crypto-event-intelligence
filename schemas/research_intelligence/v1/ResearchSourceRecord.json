{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/ResearchSourceRecord.json",
  "title": "ResearchSourceRecord",
  "description": "Metadata about a raw information source used in research.",
  "type": "object",
  "properties": {
    "source_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "access_type": {
      "type": "string"
    },
    "quality": {
      "type": "string"
    },
    "origin": {
      "type": "string"
    },
    "redistribution": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "registered_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}