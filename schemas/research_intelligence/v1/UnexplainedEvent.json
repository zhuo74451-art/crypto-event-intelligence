{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/UnexplainedEvent.json",
  "title": "UnexplainedEvent",
  "description": "An event that has been detected but cannot (yet) be explained by our research.",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "event_time": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "related_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "detected_at": {
      "type": "string"
    },
    "resolved_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}