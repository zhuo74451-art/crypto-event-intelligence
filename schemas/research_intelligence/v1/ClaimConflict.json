{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-intelligence/v1/schemas/ClaimConflict.json",
  "title": "ClaimConflict",
  "description": "A conflict (contradiction / tension) detected between claims.",
  "type": "object",
  "properties": {
    "conflict_id": {
      "type": "string"
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflict_type": {
      "type": "string"
    },
    "resolution": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "resolution_notes": {
      "type": "string"
    },
    "detected_at": {
      "type": "string"
    },
    "resolved_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}