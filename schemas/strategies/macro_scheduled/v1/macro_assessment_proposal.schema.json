{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MacroAssessmentProposal",
  "type": "object",
  "properties": {
    "proposal_id": {"type": "string"},
    "release_event_id": {"type": "string"},
    "as_of_time": {"type": "string", "format": "date-time"},
    "release_summary": {"type": "string"},
    "expectation_quality": {"type": "string"},
    "overall_status": {"type": "string"},
    "horizon_assessments": {"type": "array"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "validation_record": {"type": "object"}
  },
  "required": ["proposal_id","release_event_id","as_of_time"]
}
