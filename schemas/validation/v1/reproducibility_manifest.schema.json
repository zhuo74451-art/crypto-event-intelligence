{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reproducibility Manifest",
  "description": "Manifest for reproducing an experiment",
  "type": "object",
  "properties": {
    "experiment_id": { "type": "string" },
    "code_sha": { "type": "string" },
    "python_version": { "type": "string" },
    "platform": { "type": "string" },
    "dependency_lock_hash": { "type": "string" },
    "dataset_fingerprint": { "type": "string" },
    "configuration_hash": { "type": "string" },
    "random_seed": { "type": "integer" },
    "command": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" }
  },
  "required": ["experiment_id", "code_sha", "python_version", "random_seed"]
}
