{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prediction Record",
  "description": "A single validation prediction with confidence tracking",
  "type": "object",
  "properties": {
    "prediction_id": { "type": "string" },
    "experiment_id": { "type": "string" },
    "event_id": { "type": "string" },
    "as_of_time": { "type": "string", "format": "date-time" },
    "horizon": { "type": "string" },
    "predicted_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
    "confidence_score": { "type": "number" },
    "calibrated_probability": { "type": "number" },
    "confidence_type": { "type": "string", "enum": ["uncalibrated_score", "calibrated_probability"] },
    "model_id": { "type": "string" },
    "fold_id": { "type": "string" },
    "features_hash": { "type": "string" },
    "is_abstained": { "type": "boolean" },
    "abstention_reason": { "type": "string" }
  },
  "required": ["prediction_id", "experiment_id", "event_id", "as_of_time", "horizon", "predicted_direction"]
}
