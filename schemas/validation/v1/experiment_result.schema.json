{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Result",
  "description": "Complete experiment result with metrics and artifacts",
  "type": "object",
  "properties": {
    "experiment_id": { "type": "string" },
    "experiment_version": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "frozen", "running", "completed", "failed", "invalidated", "superseded"] },
    "data_fingerprint": { "type": "string" },
    "code_sha": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "metrics": { "type": "object" },
    "failure_reason": { "type": "string" },
    "output_artifacts": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["experiment_id", "experiment_version", "status"]
}
