{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Specification",
  "description": "Frozen specification for a validation experiment",
  "type": "object",
  "properties": {
    "experiment_id": { "type": "string" },
    "experiment_version": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "research_question": { "type": "string" },
    "hypothesis_id": { "type": "string" },
    "strategy_candidate_id": { "type": "string" },
    "dataset_id": { "type": "string" },
    "prediction_target": { "type": "string" },
    "time_horizons": { "type": "array", "items": { "type": "string" } },
    "feature_set": { "type": "array", "items": { "type": "string" } },
    "label_set": { "type": "array", "items": { "type": "string" } },
    "baseline_set": { "type": "array", "items": { "type": "string" } },
    "split_method": { "type": "string" },
    "purge_policy": { "type": "string" },
    "embargo_policy": { "type": "string" },
    "primary_metrics": { "type": "array", "items": { "type": "string" } },
    "secondary_metrics": { "type": "array", "items": { "type": "string" } },
    "maximum_trials": { "type": "integer", "minimum": 1 },
    "multiple_testing_family": { "type": "string" },
    "promotion_criteria": { "type": "string" },
    "rejection_criteria": { "type": "string" },
    "seed": { "type": "integer" }
  },
  "required": ["experiment_id", "experiment_version", "created_at"]
}
