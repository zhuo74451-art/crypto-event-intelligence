{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "strategy_hypothesis_v1.schema.json",
  "title": "StrategyHypothesisV1",
  "description": "Hypothesis generated by a strategy instance during replay.",
  "type": "object",
  "required": ["hypothesis_id", "strategy_id", "strategy_instance_id", "event_id", "asset", "time_horizon", "expected_effect", "strategy_state", "market_confirmation"],
  "properties": {
    "hypothesis_id": {"type": "string"},
    "strategy_id": {"type": "string"},
    "strategy_instance_id": {"type": "string"},
    "event_id": {"type": "string"},
    "asset": {"type": "string"},
    "time_horizon": {"type": "string"},
    "expected_effect": {"type": "object"},
    "strategy_state": {"type": "object"},
    "market_confirmation": {"type": "object"},
    "sector": {"type": "string"},
    "supporting_evidence_refs": {"type": "array", "items": {"type": "string"}},
    "opposing_evidence_refs": {"type": "array", "items": {"type": "string"}},
    "alternative_explanations": {"type": "array", "items": {"type": "string"}},
    "invalidation_conditions": {"type": "array", "items": {"type": "string"}},
    "expiration_at_utc": {"type": "string", "format": "date-time"},
    "transmission_signature": {"type": "object"},
    "transmission_coherence": {"type": "number"},
    "transmission_conflicts": {"type": "array", "items": {"type": "string"}},
    "confidence_type": {"type": "string"},
    "calibration_artifact_ref": {"type": "string"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
