{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/intelligence/historical_market/market_bar_v1.schema.json",
  "title": "MarketBarV1",
  "description": "A single OHLCV market bar for any instrument.",
  "type": "object",
  "required": [
    "bar_id", "instrument_id", "symbol", "venue", "asset_class", "instrument_type", "quote_currency",
    "interval", "open_time_utc", "close_time_utc",
    "open", "high", "low", "close", "volume",
    "source_provider", "source_snapshot_id", "retrieved_at_utc", "first_seen_at_utc",
    "data_quality"
  ],
  "properties": {
    "bar_id": {"type": "string", "pattern": "^[a-f0-9]{24}$", "description": "Deterministic SHA-256 prefix"},
    "instrument_id": {"type": "string"},
    "symbol": {"type": "string"},
    "venue": {"type": "string"},
    "asset_class": {"type": "string", "enum": ["crypto", "rates", "equities", "commodities", "fx", "macro"]},
    "instrument_type": {"type": "string", "enum": ["spot", "perp_future", "future", "option", "etf", "index", "yield", "cash", "commodity_future"]},
    "quote_currency": {"type": "string"},
    "interval": {"type": "string", "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d", "1w"]},
    "open_time_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "close_time_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "open": {"type": "number", "minimum": 0},
    "high": {"type": "number", "minimum": 0},
    "low": {"type": "number", "minimum": 0},
    "close": {"type": "number", "minimum": 0},
    "volume": {"type": "number", "minimum": 0},
    "quote_volume": {"type": "number", "minimum": 0},
    "trade_count": {"type": "integer", "minimum": 0},
    "is_adjusted": {"type": "boolean", "default": false},
    "adjustment_method": {"type": "string"},
    "is_proxy": {"type": "boolean", "default": false},
    "proxy_for": {"type": "string"},
    "source_provider": {"type": "string"},
    "source_snapshot_id": {"type": "string"},
    "retrieved_at_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "first_seen_at_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "data_quality": {"type": "string", "enum": ["exact_archived_market_data", "exact_public_api_retrieval", "verified_public_dataset", "explicit_liquid_proxy", "lower_frequency_fallback", "reconstructed_with_limits", "missing"]},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
