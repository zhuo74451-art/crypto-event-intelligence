{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/intelligence/historical_market/derivative_snapshot_v1.schema.json",
  "title": "DerivativeSnapshotV1",
  "description": "A snapshot of crypto derivative market data.",
  "type": "object",
  "required": [
    "snapshot_id", "instrument_id", "symbol", "venue", "observed_at_utc", "interval",
    "source_provider", "source_snapshot_id", "retrieved_at_utc", "data_quality"
  ],
  "properties": {
    "snapshot_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "instrument_id": {"type": "string"},
    "symbol": {"type": "string"},
    "venue": {"type": "string"},
    "observed_at_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "interval": {"type": "string", "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d"]},
    "mark_price": {"type": "number"},
    "index_price": {"type": "number"},
    "funding_rate": {"type": "number"},
    "next_funding_at_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "open_interest": {"type": "number", "minimum": 0},
    "open_interest_value": {"type": "number", "minimum": 0},
    "basis": {"type": "number"},
    "premium_index": {"type": "number"},
    "liquidation_long_volume": {"type": "number", "minimum": 0},
    "liquidation_short_volume": {"type": "number", "minimum": 0},
    "liquidation_is_proxy": {"type": "boolean", "default": false},
    "liquidation_proxy_method": {"type": "string"},
    "source_provider": {"type": "string"},
    "source_snapshot_id": {"type": "string"},
    "retrieved_at_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "data_quality": {"type": "string", "enum": ["exact_archived_market_data", "exact_public_api_retrieval", "verified_public_dataset", "explicit_liquid_proxy", "lower_frequency_fallback", "reconstructed_with_limits", "missing"]},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
