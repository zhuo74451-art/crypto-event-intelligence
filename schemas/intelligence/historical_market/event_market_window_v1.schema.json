{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/intelligence/historical_market/event_market_window_v1.schema.json",
  "title": "EventMarketWindowV1",
  "description": "Market data window around a macro event.",
  "type": "object",
  "required": [
    "window_id", "event_id", "event_family", "event_time_utc", "instrument_id",
    "pre_window_start_utc", "post_window_end_utc", "bar_interval",
    "bars_expected", "bars_present", "data_quality"
  ],
  "properties": {
    "window_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "event_id": {"type": "string"},
    "event_family": {"type": "string"},
    "event_time_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "instrument_id": {"type": "string"},
    "pre_window_start_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "post_window_end_utc": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "bar_interval": {"type": "string"},
    "bars_expected": {"type": "integer", "minimum": 0},
    "bars_present": {"type": "integer", "minimum": 0},
    "coverage_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "stale_bar_count": {"type": "integer", "minimum": 0},
    "missing_bar_count": {"type": "integer", "minimum": 0},
    "pre_event_reference_price": {"type": "number"},
    "event_bar_open": {"type": "number"},
    "event_bar_close": {"type": "number"},
    "post_event_reference_prices": {"type": "object", "additionalProperties": {"type": "number"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "data_quality": {"type": "string"},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
