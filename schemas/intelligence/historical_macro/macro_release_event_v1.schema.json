{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MacroReleaseEventV1",
  "description": "A canonical macro-economic release event with verified time and measure semantics \u2014 V2.",
  "type": "object",
  "required": [
    "event_id",
    "logical_event_key",
    "event_family",
    "country",
    "reference_period",
    "actual_release_at_utc",
    "release_time_quality",
    "release_time_verified",
    "actual_value_status",
    "measure_type",
    "event_alignment_eligible",
    "strategy_replay_eligible"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{24}$"
    },
    "logical_event_key": {
      "type": "string",
      "pattern": "^[a-f0-9]{24}$"
    },
    "event_family": {
      "type": "string",
      "enum": [
        "us_cpi",
        "us_core_cpi",
        "us_nonfarm_payrolls",
        "us_unemployment_rate",
        "us_core_pce",
        "us_fomc_rate_decision",
        "us_retail_sales",
        "us_ppi",
        "us_gdp",
        "us_ism_manufacturing",
        "us_initial_jobless_claims",
        "fomc_minutes"
      ]
    },
    "series_id": {
      "type": "string"
    },
    "country": {
      "const": "US"
    },
    "currency": {
      "const": "USD"
    },
    "reference_period": {
      "type": "string",
      "pattern": "^\\d{4}-(Q[1-4]|\\d{2})$"
    },
    "scheduled_release_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "actual_release_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "release_time_timezone": {
      "type": "string",
      "default": "America/New_York"
    },
    "release_time_quality": {
      "type": "string",
      "enum": [
        "verified_official_release_page",
        "verified_official_calendar",
        "verified_official_archive",
        "reconstructed_official_date_only",
        "estimated_unusable",
        "missing"
      ]
    },
    "release_time_verified": {
      "type": "boolean"
    },
    "release_time_source_url": {
      "type": "string"
    },
    "release_time_source_snapshot_id": {
      "type": "string"
    },
    "event_alignment_eligible": {
      "type": "boolean"
    },
    "actual_initial": {
      "type": [
        "number",
        "null"
      ]
    },
    "actual_initial_unit": {
      "type": "string"
    },
    "actual_value_status": {
      "type": "string",
      "enum": [
        "verified_initial_from_release",
        "derived_from_verified_release_table",
        "current_latest_only",
        "reconstructed_with_limits",
        "missing"
      ]
    },
    "measure_type": {
      "type": "string"
    },
    "primary_measure": {
      "type": "string"
    },
    "secondary_measures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strategy_replay_eligible": {
      "type": "boolean"
    },
    "prior_as_known_then": {
      "type": [
        "number",
        "null"
      ]
    },
    "prior_revised_latest": {
      "type": [
        "number",
        "null"
      ]
    },
    "revision_status": {
      "type": "string",
      "enum": [
        "initial",
        "revised",
        "multiple_revisions",
        "unavailable"
      ]
    },
    "official_source_name": {
      "type": "string"
    },
    "official_source_url": {
      "type": "string",
      "format": "uri"
    },
    "official_release_id": {
      "type": "string"
    },
    "official_document_hash": {
      "type": "string"
    },
    "consensus_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "consensus_unit": {
      "type": "string"
    },
    "consensus_observed_at_utc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "consensus_source_count": {
      "type": "integer",
      "minimum": 0
    },
    "point_in_time_quality": {
      "type": "string",
      "enum": [
        "strict_archived_pre_event",
        "verified_pre_event_media",
        "reconstructed_multi_source",
        "single_source_reconstructed",
        "missing"
      ]
    },
    "consensus_aggregation_method": {
      "type": "string"
    },
    "consensus_independence_groups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "surprise_raw": {
      "type": [
        "number",
        "null"
      ]
    },
    "surprise_standardized": {
      "type": [
        "number",
        "null"
      ]
    },
    "surprise_method": {
      "type": "string"
    },
    "surprise_window": {
      "type": "string"
    },
    "surprise_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "as_known_then_cutoff_utc": {
      "type": "string",
      "format": "date-time"
    },
    "current_best_generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "first_seen_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "retrieved_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "provider_observation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}