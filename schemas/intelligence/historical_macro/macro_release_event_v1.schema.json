{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MacroReleaseEventV1",
  "description": "A scheduled macro-economic release event with actual value, prior, revision status, and consensus expectation.",
  "type": "object",
  "required": [
    "event_id",
    "event_family",
    "series_id",
    "country",
    "currency",
    "reference_period",
    "scheduled_release_at_utc",
    "actual_release_at_utc",
    "first_seen_at_utc",
    "retrieved_at_utc",
    "actual_initial",
    "actual_initial_unit",
    "prior_as_known_then",
    "prior_revised_latest",
    "revision_status",
    "official_source_name",
    "official_source_url",
    "as_known_then_cutoff_utc",
    "current_best_generated_at_utc"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{24}$"
    },
    "event_family": {
      "type": "string",
      "enum": [
        "us_cpi",
        "us_core_cpi",
        "us_nonfarm_payrolls",
        "us_unemployment_rate",
        "us_core_pce",
        "us_fomc_rate_decision",
        "us_retail_sales",
        "us_ppi",
        "us_gdp",
        "us_ism_manufacturing",
        "us_initial_jobless_claims",
        "fomc_minutes"
      ]
    },
    "series_id": {
      "type": "string"
    },
    "country": {
      "const": "US"
    },
    "currency": {
      "const": "USD"
    },
    "reference_period": {
      "type": "string",
      "pattern": "^\\d{4}-(Q[1-4]|\\d{2})$"
    },
    "scheduled_release_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "actual_release_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "first_seen_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "retrieved_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "actual_initial": {
      "type": [
        "number",
        "null"
      ]
    },
    "actual_initial_unit": {
      "type": "string"
    },
    "prior_as_known_then": {
      "type": [
        "number",
        "null"
      ]
    },
    "prior_revised_latest": {
      "type": [
        "number",
        "null"
      ]
    },
    "revision_status": {
      "type": "string",
      "enum": [
        "initial",
        "revised",
        "multiple_revisions",
        "unavailable"
      ]
    },
    "official_source_name": {
      "type": "string"
    },
    "official_source_url": {
      "type": "string",
      "format": "uri"
    },
    "official_release_id": {
      "type": "string"
    },
    "official_document_hash": {
      "type": "string"
    },
    "consensus_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "consensus_unit": {
      "type": "string"
    },
    "consensus_observed_at_utc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "consensus_source_count": {
      "type": "integer",
      "minimum": 0
    },
    "point_in_time_quality": {
      "type": "string",
      "enum": [
        "strict_archived_pre_event",
        "verified_pre_event_media",
        "reconstructed_multi_source",
        "single_source_reconstructed",
        "missing"
      ]
    },
    "surprise_raw": {
      "type": [
        "number",
        "null"
      ]
    },
    "surprise_standardized": {
      "type": [
        "number",
        "null"
      ]
    },
    "surprise_method": {
      "type": "string"
    },
    "surprise_window": {
      "type": "string"
    },
    "surprise_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "as_known_then_cutoff_utc": {
      "type": "string",
      "format": "date-time"
    },
    "current_best_generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "data_quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}