# env.radar.example -- EnvironmentFile template
# Copy to /opt/crypto-event-intel-watchers/.env, chmod 0400

# === Required Secrets ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLISH_CHAT_IDS=
ETHERSCAN_API_KEY=

# === Core Cycle ===
V09_RADAR_LOAD_LOCAL_SECRETS=false

# === Send Control ===
V09_RADAR_NO_SEND=true

# === Optional overrides (uncomment to customize) ===
# V09_RADAR_HOURS=24
# V09_RADAR_LIMIT_ALERTS=100
# V09_RADAR_SAMPLE_IF_NO_KEY=false
# V09_RADAR_SEND_BOARD=true
# V09_RADAR_SEND_QUALITY_SUMMARY=true
# V09_RADAR_QUALITY_SUMMARY_MIN_COMPUTED=1
# V09_RADAR_TIMEOUT_SECONDS=3300
# V09_RADAR_EVALUATE_ALERT_OUTCOMES=true
# V09_RADAR_REFRESH_V11_QUALITY_REPORTS=true