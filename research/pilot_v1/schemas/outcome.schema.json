{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/outcome.schema.json",
  "title": "Outcome",
  "description": "Price reaction outcome for a registered research unit. Physically separate from Registration. No abnormal_return field.",
  "type": "object",
  "required": [
    "outcome_id", "registration_ref", "raw_market_reaction", "registered_benchmark_relative_reaction",
    "historical_materiality", "event_time_uncertainty", "calculated_at_utc"
  ],
  "properties": {
    "outcome_id": {"type": "string"},
    "registration_ref": {"type": "string", "description": "Reference to the Registration this outcome belongs to."},
    "raw_market_reaction": {
      "type": "object",
      "required": ["window", "absolute_change_pct", "direction"],
      "properties": {
        "window": {"type": "string", "enum": ["1h", "4h", "24h"]},
        "absolute_change_pct": {"type": "number"},
        "direction": {"type": "string", "enum": ["positive", "negative", "flat"]}
      }
    },
    "registered_benchmark_relative_reaction": {
      "type": "object",
      "description": "Reaction relative to the primary benchmark registered for this study. NOT called abnormal_return.",
      "required": ["benchmark", "relative_change_pct"],
      "properties": {
        "benchmark": {"type": "string"},
        "relative_change_pct": {"type": "number"}
      }
    },
    "historical_materiality": {
      "type": "object",
      "description": "Assessment of whether the reaction exceeds expected historical volatility.",
      "required": ["assessment", "note"],
      "properties": {
        "assessment": {"type": "string", "enum": ["material", "not_material", "insufficient_data"]},
        "note": {"type": "string"}
      }
    },
    "event_time_uncertainty": {
      "type": "object",
      "required": ["estimated_uncertainty_seconds"],
      "properties": {
        "estimated_uncertainty_seconds": {"type": "integer"},
        "note": {"type": "string"}
      }
    },
    "price_alignment_lag": {
      "type": "object",
      "properties": {
        "t0_lag_seconds": {"type": "integer"},
        "t1_lag_seconds": {"type": "integer"}
      }
    },
    "price_precision": {
      "type": "object",
      "properties": {
        "provider": {"type": "string"},
        "interval_seconds": {"type": "integer"},
        "precision_note": {"type": "string"}
      }
    },
    "calculated_at_utc": {"type": "string", "format": "date-time"}
  }
}
