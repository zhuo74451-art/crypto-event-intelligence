{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/claim_evidence_record.schema.json",
  "title": "ClaimEvidenceRecord",
  "description": "A record linking a claim about an event to its supporting evidence artifacts, with precise evidence role and claim evidence status. No global source reputation scores.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_id", "claim", "evidence_artifacts", "evidence_relations", "evidence_role", "claim_evidence_status", "independence_groups", "provenance_path", "created_at_utc"],
  "properties": {
    "record_id": {"type": "string"},
    "evidence_role": {
      "type": "string",
      "enum": ["primary_record", "originator_statement", "independent_verification", "carrier_or_relay", "interpretation", "derived_measurement", "anonymous_or_unverified_claim"],
      "description": "The role this evidence record plays in the event intelligence pipeline."
    },
    "claim_evidence_status": {
      "type": "string",
      "enum": ["directly_verified", "supported", "single_source_supported", "self_reported", "derived", "disputed", "interpretation_only", "insufficient_evidence"],
      "description": "The verifiability status of the claim supported by this evidence record."
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "claimant", "claim_time_utc", "claim_type"],
      "properties": {
        "statement": {"type": "string"},
        "claimant": {"type": "string"},
        "claim_time_utc": {"type": "string", "format": "date-time"},
        "claim_type": {"type": "string", "enum": ["fact", "interpretation", "prediction", "rumor"]}
      }
    },
    "evidence_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "artifact_type", "content_hash", "source"],
        "properties": {
          "artifact_id": {"type": "string"},
          "artifact_type": {"type": "string", "enum": ["on_chain_tx", "screenshot", "api_response", "official_doc", "article", "social_post", "analyst_note"]},
          "content_hash": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    },
    "evidence_relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "relation_type"],
        "properties": {
          "evidence_id": {"type": "string"},
          "relation_type": {"type": "string", "enum": ["supports", "contradicts", "contextualizes", "unrelated"]},
          "detail": {"type": "string"}
        }
      }
    },
    "provenance_path": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hop", "from_source", "to_source", "timestamp_utc"],
        "properties": {
          "hop": {"type": "integer"},
          "from_source": {"type": "string"},
          "to_source": {"type": "string"},
          "timestamp_utc": {"type": "string", "format": "date-time"},
          "transformation": {"type": "string"}
        }
      }
    },
    "independence_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group_id", "members"],
        "properties": {
          "group_id": {"type": "string"},
          "members": {"type": "array", "items": {"type": "string"}},
          "independence_status": {"type": "string", "enum": ["independent", "shared_source", "circular", "unknown"]}
        }
      }
    },
    "created_at_utc": {"type": "string", "format": "date-time"},
    "updated_at_utc": {"type": "string", "format": "date-time"}
  }
}
