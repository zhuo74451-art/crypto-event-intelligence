{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhuo74451-art/crypto-event-intelligence/schemas/registration.schema.json",
  "title": "Registration",
  "description": "Pre-registration of a research unit's study parameters. Must be created before outcome data is revealed or computed.",
  "type": "object",
  "required": [
    "registration_id", "research_unit_ref", "target_asset", "selected_clock", "primary_t0",
    "t0_type", "primary_window", "primary_benchmark", "registration_time_utc",
    "git_commit", "file_sha256", "data_partition", "outcome_status"
  ],
  "properties": {
    "registration_id": {"type": "string"},
    "research_unit_ref": {"type": "string"},
    "target_asset": {"type": "string", "description": "The asset whose price movement is being studied."},
    "selected_clock": {"type": "string", "enum": ["broadcast_time", "event_time", "block_time"]},
    "primary_t0": {"type": "string", "format": "date-time", "description": "The primary t0 anchor time."},
    "t0_type": {"type": "string", "enum": ["broadcast_time", "event_time", "block_time", "estimated"]},
    "t0_uncertainty_seconds": {"type": "integer", "description": "Estimated uncertainty in t0 in seconds."},
    "primary_window": {
      "type": "object",
      "required": ["duration_seconds", "window_type"],
      "properties": {
        "duration_seconds": {"type": "integer"},
        "window_type": {"type": "string", "enum": ["t0_to_t_plus_1h", "t0_to_t_plus_4h", "t0_to_t_plus_24h", "custom"]}
      }
    },
    "primary_benchmark": {"type": "string", "description": "Benchmark asset for relative reaction. Must differ from target_asset."},
    "sensitivity_benchmarks": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Additional benchmarks for sensitivity analysis."
    },
    "pre_event_movement_check": {
      "type": "object",
      "properties": {
        "window_before_t0_seconds": {"type": "integer"},
        "threshold_bps": {"type": "integer"},
        "movement_detected": {"type": "boolean"}
      }
    },
    "registration_time_utc": {"type": "string", "format": "date-time"},
    "git_commit": {"type": "string"},
    "file_sha256": {"type": "string"},
    "data_partition": {"type": "string", "enum": ["development", "calibration", "holdout"]},
    "outcome_status": {
      "type": "string",
      "enum": ["not_revealed"],
      "description": "MUST be 'not_revealed' at registration time. Outcome data is a separate schema."
    },
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"target_asset": {"const": "${primary_benchmark}"}}},
      "then": {"description": "target_asset and primary_benchmark MUST differ. This registration would be rejected."}
    }
  ]
}
