# ============================================================
# Local TG Publisher — Environment Variable Template
# ============================================================
# Copy this file to config/local_tg_publisher.env and fill in values.
# NEVER commit config/local_tg_publisher.env to Git.
#
# Usage:
#   cp config/local_tg_publisher.env.example config/local_tg_publisher.env
#   (edit config/local_tg_publisher.env with real values)
# ============================================================

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Required: Telegram Chat ID (test group first, NOT production)
# Can be a single ID or comma-separated list
TELEGRAM_CHAT_ID=

# Publish mode: test | production
# "test" = send only to test chat_id (safe default)
# "production" = send to all configured chat_ids
PUBLISH_MODE=test

# Polling interval in seconds (how often to rebuild cards and check for new)
POLL_INTERVAL_SECONDS=60

# Maximum cards to send per cycle (rate limiting)
MAX_SEND_PER_CYCLE=3

# Dry run: true = preview only, no TG send
# Set to false ONLY after verifying test messages work
DRY_RUN=true

# Optional: Override log file path
# LOG_PATH=logs/local_tg_publisher.log

# Optional: Override state database path
# STATE_DB_PATH=data/local_tg_publisher_state.sqlite

# Optional: Comma-separated blocked keywords in card text
# Cards containing these will be skipped
# BLOCKED_KEYWORDS=买入,卖出,做多,做空,开仓,止盈,止损
